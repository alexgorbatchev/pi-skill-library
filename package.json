{
  "name": "@alexgorbatchev/pi-skill-library",
  "version": "1.0.2",
  "description": "Pi extension that exposes skills-library roots through /library:<skill-name> commands.",
  "type": "module",
  "author": "Alex Gorbatchev",
  "license": "MIT",
  "homepage": "https://github.com/alexgorbatchev/pi-skill-library#readme",
  "bugs": {
    "url": "https://github.com/alexgorbatchev/pi-skill-library/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexgorbatchev/pi-skill-library.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "skills",
    "skill",
    "library"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@alexgorbatchev/typescript-ai-policy": "^1.0.5",
    "@mariozechner/pi-coding-agent": "0.65.2",
    "@types/node": "25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "6.0.2"
  },
  "scripts": {
    "fmt": "bun --bun oxfmt --write .",
    "fmt:check": "bun --bun oxfmt --check .",
    "check": "bun run fmt:check && bun --bun oxlint . && tsgo --noEmit",
    "test": "PI_OFFLINE=1 bun x pi --no-extensions -e ./src/index.ts --list-models > /dev/null 2>&1",
    "test:local": "bun x pi -e ./src/index.ts"
  }
}
